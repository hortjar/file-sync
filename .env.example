# Copy to .env.prod for production, .env.dev for development
# NEVER commit .env.dev or .env.prod

# --- Core (all environments) ---
DATABASE_URL=postgresql://filesync:changeme@localhost:5432/filesync
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_REFRESH_SECRET=change-this-too
NODE_ENV=development

# CORS — comma-separated allowed origins (use * for a self-hosted setup)
CORS_ORIGIN=*

# Storage — where content-addressed file blobs live.
#   • Local dev (bun):     a path the server writes to, e.g. ./data/blobs
#   • Docker stack (prod): the HOST directory that holds ALL data — postgres, blobs,
#     and caddy certs all live under it. Docker creates the subdirs on first start.
STORAGE_PATH=/storage/filesync

# --- Ports ---
# Local dev server listen port.
PORT=3001
# Docker stack: ports the API and web containers listen on AND publish to the host, so
# you can reach them directly at http://<host-ip>:<port>. Caddy also proxies to them
# (reading the same values from the Caddyfile). FRONTEND_PORT defaults to 8080 so it
# doesn't clash with Caddy on 80/443.
BACKEND_PORT=3001
FRONTEND_PORT=8080

# --- Production only (docker-compose.prod.yml) ---
# Postgres password for the Docker database (also used in the server DATABASE_URL)
POSTGRES_PASSWORD=change-this-to-a-long-random-string
# Domain Caddy serves and requests the Let's Encrypt cert for
FILESYNC_DOMAIN=filesync.example.com
# Server URL baked into the web dashboard build (must match your domain)
VITE_SERVER_URL=https://filesync.example.com

# Default admin account, created idempotently on the first server start.
# CHANGE THESE before deploying — the password only applies when the user is created.
ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=change-this-too
