# Copy to .env.prod for production, .env.dev for development
# NEVER commit .env.dev or .env.prod

# --- Core (all environments) ---
DATABASE_URL=postgresql://filesync:changeme@localhost:5432/filesync
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_REFRESH_SECRET=change-this-too
NODE_ENV=development

# --- Authentication backend ---
# "local"     → this app's own JWT auth (default; JWT_SECRET/JWT_REFRESH_SECRET used).
# "universal" → delegate identity to the shared Universal Admin server. Access tokens
#               are verified against its JWKS, login/register/refresh/logout are proxied
#               there, and users are provisioned locally on first sight. Other routes
#               keep working unchanged.
AUTH_MODE=local
UNIVERSAL_AUTH_URL=http://localhost:9200
UNIVERSAL_AUTH_APP=file-sync
# Optional: API key (admin console → Apps → Manage) for shipping logs to the collector.
# UNIVERSAL_AUTH_API_KEY=uak_xxxx.xxxxxxxx

# Cross-subdomain SSO: in universal mode this backend re-issues the refresh token
# as an HttpOnly cookie on COOKIE_DOMAIN, so a browser session here is shared with
# every sibling app (log in once). The JSON token response is unchanged, so the
# desktop app is unaffected. Set COOKIE_DOMAIN to your parent domain in production.
ENABLE_AUTH_COOKIES=true
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS — comma-separated allowed origins (use * for a self-hosted setup)
CORS_ORIGIN=*

# Storage — where content-addressed file blobs live.
#   • Local dev (bun):     a path the server writes to, e.g. ./data/blobs
#   • Docker stack (prod): the HOST directory that holds ALL data — postgres, blobs,
#     and caddy certs all live under it. Docker creates the subdirs on first start.
STORAGE_PATH=/storage/filesync

# --- Ports ---
# Local dev server listen port.
PORT=3001
# Docker stack: ports the API and web containers listen on AND publish to the host, so
# you can reach them directly at http://<host-ip>:<port>. Caddy also proxies to them
# (reading the same values from the Caddyfile). FRONTEND_PORT defaults to 8080 so it
# doesn't clash with Caddy on 80/443.
BACKEND_PORT=3001
FRONTEND_PORT=8080
# Host ports Caddy publishes (the unified entry: /, /api, /ws). Override 80/443 when
# they're taken — e.g. point a cloudflared tunnel at CADDY_HTTP_PORT.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# --- Production only (docker-compose.prod.yml) ---
# Postgres password for the Docker database (also used in the server DATABASE_URL)
POSTGRES_PASSWORD=change-this-to-a-long-random-string
# Caddy site address. Default ':80' serves plain HTTP for any host (no auto-HTTPS) —
# use this behind a reverse proxy / cloudflared tunnel that terminates TLS. Set it to a
# domain (e.g. filesync.example.com) for Caddy to obtain a Let's Encrypt cert itself.
FILESYNC_DOMAIN=:80
# Server URL baked into the web dashboard build (must match your domain)
VITE_SERVER_URL=https://filesync.example.com

# Default admin account, created idempotently on the first server start.
# CHANGE THESE before deploying — the password only applies when the user is created.
ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=change-this-too
