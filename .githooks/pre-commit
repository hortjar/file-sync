#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

bump_patch() {
    local major minor patch
    IFS='.' read -r major minor patch <<< "$1"
    printf '%s.%s.%d' "$major" "$minor" "$((patch + 1))"
}

# Read the first "version": "..." value from a JSON file.
read_json_version() {
    perl -ne 'if (/^\s*"version":\s*"([^"]+)"/) { print $1; exit }' "$1"
}

# Replace "version": "<old>" with "version": "<new>" in a JSON file.
write_json_version() {
    local file="$1" old="$2" new="$3"
    local old_esc
    old_esc=$(printf '%s' "$old" | sed 's/\./\\./g')
    perl -pi -e "s/\"version\": \"${old_esc}\"/\"version\": \"${new}\"/" "$file"
}

# ── Desktop: tauri.conf.json ─────────────────────────────────────────────────
TAURI_CONF="apps/desktop/src-tauri/tauri.conf.json"
tauri_old=$(read_json_version "$TAURI_CONF")
tauri_new=$(bump_patch "$tauri_old")
write_json_version "$TAURI_CONF" "$tauri_old" "$tauri_new"
git add "$TAURI_CONF"

# ── Desktop: Cargo.toml ──────────────────────────────────────────────────────
CARGO_TOML="apps/desktop/src-tauri/Cargo.toml"
tauri_old_esc=$(printf '%s' "$tauri_old" | sed 's/\./\\./g')
perl -pi -e "s/^version = \"${tauri_old_esc}\"/version = \"${tauri_new}\"/" "$CARGO_TOML"
git add "$CARGO_TOML"

# ── Desktop: package.json ────────────────────────────────────────────────────
DESKTOP_PKG="apps/desktop/package.json"
desktop_old=$(read_json_version "$DESKTOP_PKG")
desktop_new=$(bump_patch "$desktop_old")
write_json_version "$DESKTOP_PKG" "$desktop_old" "$desktop_new"
git add "$DESKTOP_PKG"

# ── Server: package.json ─────────────────────────────────────────────────────
SERVER_PKG="apps/server/package.json"
server_old=$(read_json_version "$SERVER_PKG")
server_new=$(bump_patch "$server_old")
write_json_version "$SERVER_PKG" "$server_old" "$server_new"
git add "$SERVER_PKG"

printf '\n📦 version bump\n'
printf '   desktop  %s → %s\n' "$tauri_old" "$tauri_new"
printf '   server   %s → %s\n' "$server_old" "$server_new"
