#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

bump_patch() {
    local major minor patch
    IFS='.' read -r major minor patch <<< "$1"
    printf '%s.%s.%d' "$major" "$minor" "$((patch + 1))"
}

# Read the first "version": "..." value from a JSON file.
read_json_version() {
    perl -ne 'if (/^\s*"version":\s*"([^"]+)"/) { print $1; exit }' "$1"
}

# Replace "version": "<old>" with "version": "<new>" in a JSON file.
write_json_version() {
    local file="$1" old="$2" new="$3"
    local old_esc
    old_esc=$(printf '%s' "$old" | sed 's/\./\\./g')
    perl -pi -e "s/\"version\": \"${old_esc}\"/\"version\": \"${new}\"/" "$file"
}

# Bump a JSON package's "version" and re-stage it. Prints the change.
bump_json_pkg() {
    local file="$1" label="$2" old new
    old=$(read_json_version "$file")
    new=$(bump_patch "$old")
    write_json_version "$file" "$old" "$new"
    git add "$file"
    printf '   %-8s %s → %s\n' "$label" "$old" "$new"
}

# Which areas have staged changes?
staged=$(git diff --cached --name-only --diff-filter=ACMR)
changed() { grep -q "$1" <<< "$staged"; }

web_changed=false
server_changed=false
desktop_changed=false
changed '^apps/web/'     && web_changed=true || true
changed '^apps/server/'  && server_changed=true || true
changed '^apps/desktop/' && desktop_changed=true || true

# Shared packages feed every app — bump all three when they change.
if changed '^packages/'; then
    web_changed=true
    server_changed=true
    desktop_changed=true
fi

if [[ "$web_changed" == false && "$server_changed" == false && "$desktop_changed" == false ]]; then
    exit 0
fi

printf '\n📦 version bump\n'

if [[ "$server_changed" == true ]]; then
    bump_json_pkg "apps/server/package.json" "server"
fi

if [[ "$web_changed" == true ]]; then
    bump_json_pkg "apps/web/package.json" "web"
fi

if [[ "$desktop_changed" == true ]]; then
    TAURI_CONF="apps/desktop/src-tauri/tauri.conf.json"
    CARGO_TOML="apps/desktop/src-tauri/Cargo.toml"
    tauri_old=$(read_json_version "$TAURI_CONF")
    tauri_new=$(bump_patch "$tauri_old")
    write_json_version "$TAURI_CONF" "$tauri_old" "$tauri_new"
    tauri_old_esc=$(printf '%s' "$tauri_old" | sed 's/\./\\./g')
    perl -pi -e "s/^version = \"${tauri_old_esc}\"/version = \"${tauri_new}\"/" "$CARGO_TOML"
    git add "$TAURI_CONF" "$CARGO_TOML"
    bump_json_pkg "apps/desktop/package.json" "desktop"
    printf '   %-8s %s → %s (tauri + cargo)\n' "tauri" "$tauri_old" "$tauri_new"
fi
