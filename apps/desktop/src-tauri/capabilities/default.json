{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for FileSync desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "sql:default",
    "dialog:default",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-applog-read-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-home-meta-recursive",
    "fs:allow-remove",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "/Volumes/**/*" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "/Volumes/**/*" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "/Volumes/**/*" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "/Volumes/**/*" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "/Volumes/**/*" }]
    },
    {
      "identifier": "fs:allow-create",
      "allow": [{ "path": "/Volumes/**/*" }]
    },
    "log:default",
    "notification:default",
    "updater:default",
    "process:default"
  ]
}
